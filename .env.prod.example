# Database
POSTGRES_USER=lovelion
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=lovelion
DATABASE_URL=postgres://lovelion:CHANGE_ME@postgres:5432/lovelion?sslmode=disable

# Auth
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# CORS (comma-separated origins, leave empty if frontend proxies all API calls)
CORS_ORIGINS=

# Cloudflare R2 (image storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_DOMAIN=

# AI Receipt Extraction (Google Gemini)
# Get API key: https://aistudio.google.com/apikey
RECEIPT_EXTRACT_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
RECEIPT_EXTRACT_RATE_LIMIT_PER_DAY=20

# Frontend
NUXT_PUBLIC_API_BASE=
PORT=3000
