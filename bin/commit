#!/bin/bash

# LoveLion AI Commit Helper
# Usage: ./bin/commit "primary message" "secondary message (optional)"

if [ -z "$1" ]; then
    echo "Error: Primary commit message is required."
    echo "Usage: $0 "primary message" ["secondary message"]"
    exit 1
fi

# Set AI Identity
git config user.name "Antigravity"

# Commit
if [ -z "$2" ]; then
    git commit -m "$1"
else
    git commit -m "$1" -m "$2"
fi

# Cleanup
git config --unset user.name

echo "✅ Committed as Antigravity."
